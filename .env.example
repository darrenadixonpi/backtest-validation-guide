# Copy to .env for local dev, and set the same vars in
# Vercel → Project → Settings → Environment Variables for production.

# GitHub — fine-grained PAT, scoped to Issues: Read & Write on THIS repo only.
# Required; without it the form falls back to opening a prefilled GitHub issue URL.
GITHUB_TOKEN=

# Cloudflare Turnstile — bot check. Set BOTH together, or leave BOTH blank to disable.
#   - site key is public (shipped to the browser; must be PUBLIC_-prefixed for Astro)
#   - secret key is server-only — never expose it
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Redis — shared, cross-instance rate-limit store (node-redis over TCP).
# Auto-injected as REDIS_URL when you connect the Redis store to the project in Vercel.
# If unset, the function falls back to a best-effort per-instance in-memory limiter.
REDIS_URL=
